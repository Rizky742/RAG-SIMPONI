# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/database_name

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
# Optional: custom endpoint (Azure / proxy). Leave unset to use the official OpenAI API.
# BASE_URL=

# LLM Settings
# Reasoning models (gpt-5.x, o-series) and gpt-4o family are both supported;
# the app auto-selects the correct token parameter per model.
LLM_MODEL=gpt-5.4-mini
MAX_ROWS_RETURNED=500
SQL_TIMEOUT_SECONDS=30
REQUEST_TIMEOUT=30

# Application Settings
APP_ENV=production
